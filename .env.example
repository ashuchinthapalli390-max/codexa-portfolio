# CodeXa Agency — Environment Variables Reference
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file with real secret values.

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Production: Aiven MySQL connection string
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME?ssl-mode=REQUIRED
DATABASE_URL="mysql://placeholder_user:placeholder_password@placeholder_host:3306/placeholder_db?ssl-mode=REQUIRED"

# Optional: Path to CA Certificate for SSL verification with Aiven MySQL (if needed)
AIVEN_CA_CERT_PATH="certs/ca.pem"

# ─── AUTHENTICATION & SESSIONS ────────────────────────────────────────────────
# 64-character hex string — must remain STABLE across deployments.
# Generate: openssl rand -hex 32
AUTH_SECRET="placeholder_secret_hex_64_characters_long_stable_key"

# ─── OWNER BOOTSTRAP CREDENTIALS ──────────────────────────────────────────────
# Initial Owner credentials used to seed/bootstrap the database.
OWNER_EMAIL="owner@codexa.agency"
OWNER_PASSWORD="placeholder_secure_owner_password_here"
OWNER_NAME="Ashu"

# ─── APPLICATION PARAMETERS ──────────────────────────────────────────────────
# Required for absolute URL generation (e.g., sharing links, meta tags).
# Set to your Vercel deployment URL in production.
NEXT_PUBLIC_APP_URL="https://placeholder-domain.vercel.app"

# ─── VERCEL BLOB STORAGE ──────────────────────────────────────────────────────
# Token for Vercel Blob read/write operations (legacy or fallback uploads).
# Do not prefix with NEXT_PUBLIC_ — keep this server-only.
BLOB_READ_WRITE_TOKEN="placeholder_blob_read_write_token_here"
