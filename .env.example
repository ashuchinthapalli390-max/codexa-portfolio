# CodeXa Agency — Environment Variables Reference
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file with real secret values.

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Production: Aiven MySQL connection string
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME?ssl-mode=REQUIRED
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── AUTHENTICATION & SESSIONS ────────────────────────────────────────────────
# Hex string for session encryption cookie (64 characters long)
# Generate: openssl rand -hex 32
AUTH_SECRET="replace-with-long-random-secret"

# ─── OWNER BOOTSTRAP CREDENTIALS ──────────────────────────────────────────────
OWNER_EMAIL="owner@example.com"
OWNER_PASSWORD="change-this-password"
OWNER_NAME="Owner"
OWNER_ACCESS_KEY="CODEXA-OWNER-TEST-KEY"

# ─── ADMIN TEST CREDENTIALS ───────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
ADMIN_NAME="Admin"
ADMIN_ACCESS_KEY="CODEXA-ADMIN-TEST-KEY"

# ─── TEAM MEMBER TEST CREDENTIALS ─────────────────────────────────────────────
TEAM_USERNAME="teamuser"
TEAM_PASSWORD="change-this-password"
TEAM_DISPLAY_NAME="Team Member"
TEAM_ACCESS_KEY="CODEXA-TEAM-TEST-KEY"

# ─── STORAGE (Vercel Blob) ────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="optional-if-used"

# ─── DOMAIN PARAMETERS ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
