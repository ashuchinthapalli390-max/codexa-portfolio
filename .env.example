# CodeXa Agency — Environment Variables Reference
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file with real secret values.

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Production: Aiven MySQL connection string
# Format: mysql://USERNAME:URL_ENCODED_PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=

# Local development only (SQLite):
# DATABASE_URL=file:./prisma/dev.db

# ─── SESSION SECURITY ─────────────────────────────────────────────────────────
# 64-character hex string — must remain STABLE across deployments.
# Changing this invalidates all existing sessions.
# Generate: openssl rand -hex 32
SESSION_SECRET=

# ─── OWNER ACCOUNT (used by bootstrap + password verification) ────────────────
# Email address for the Owner account
OWNER_EMAIL=

# bcrypt hash of the Owner's password (12 rounds).
# Generate locally: node -e "const b=require('bcryptjs'); b.hash('YourPassword',12).then(console.log)"
# Then paste the hash here — never store plaintext passwords.
OWNER_PASSWORD_HASH=

# ─── BOOTSTRAP (one-time production setup) ────────────────────────────────────
# Secret required to call POST /api/auth/bootstrap.
# Remove or unset after first successful bootstrap.
# Generate: openssl rand -hex 24
BOOTSTRAP_SECRET=

# ─── OWNER MASTER KEY (permanent bypass key for OWNER login) ─────────────────
# This key ALWAYS grants OWNER-level pre-auth regardless of database state.
# It is compared after normalization (trim + uppercase).
# Change this value to rotate the master key. Keep it secret.
# Do NOT use NEXT_PUBLIC_ for this variable.
OWNER_MASTER_KEY=

# ─── UPLOAD STORAGE ───────────────────────────────────────────────────────────
# NOTE: On Vercel, the local filesystem is ephemeral.
# Profile images uploaded via the admin panel will NOT persist between deployments.
# Consider migrating to a cloud storage solution (e.g., Vercel Blob, Cloudflare R2, S3).
# No additional variables required for the current local-filesystem implementation.

# ─── APPLICATION URL ─────────────────────────────────────────────────────────
# Required for absolute URL generation if needed (e.g., email links).
# Set to your Vercel deployment URL in production.
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
