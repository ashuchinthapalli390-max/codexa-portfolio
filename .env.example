# CodeXa Agency — Environment Variables Reference
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file with real secret values.
# Add REAL values to Vercel Dashboard → Project → Settings → Environment Variables.

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Production: Aiven MySQL connection string
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME?ssl-mode=REQUIRED
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── AUTHENTICATION & SESSIONS ────────────────────────────────────────────────
# Hex string for HMAC access key hashing (must be stable — never change after seeding)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-long-random-secret"

# ─── APP URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── OWNER BOOTSTRAP CREDENTIALS ──────────────────────────────────────────────
OWNER_NAME="Ashu"
OWNER_EMAIL="owner@example.com"
OWNER_PASSWORD="change-this-password"
OWNER_ACCESS_KEY="CODEXA-OWNER-KEY"

# ─── ADMIN CREDENTIALS ────────────────────────────────────────────────────────
ADMIN_NAME="Read Only Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
ADMIN_ACCESS_KEY="CODEXA-ADMIN-KEY"

# ─── TEAM MEMBER CREDENTIALS ──────────────────────────────────────────────────
TEAM_USERNAME="teamuser"
TEAM_DISPLAY_NAME="Team Member"
TEAM_PASSWORD="change-this-password"
TEAM_ACCESS_KEY="CODEXA-TEAM-KEY"

# ─── STORAGE (Vercel Blob) ────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="optional-if-still-used"
