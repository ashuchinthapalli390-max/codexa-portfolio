// Prisma schema for CodeXa Agency — Full Auth System
// Database: MySQL (Aiven production)
// Local dev: use schema.sqlite.prisma with SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── USER ACCOUNTS ───────────────────────────────────────────────────────────
model User {
  id           String    @id @default(cuid()) @db.VarChar(30)
  username     String?   @unique @db.VarChar(191)
  email        String?   @unique @db.VarChar(191)
  fullName     String?   @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  // role values: "OWNER" | "ADMIN" | "TEAM_MEMBER"
  role         String    @db.VarChar(20)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      TeamProfile?
  sessions     Session[]
  accessKeys   AccessKey[]
}

// ─── TEAM PROFILES ────────────────────────────────────────────────────────────
model TeamProfile {
  id                 String    @id @default(cuid()) @db.VarChar(30)
  userId             String?   @unique @db.VarChar(30)
  // memberType values: "LEADERSHIP" | "CORE_TEAM"
  memberType         String    @db.VarChar(20)
  // leadershipPosition values: "FOUNDER" | "CO_FOUNDER" | "CEO" | null
  leadershipPosition String?   @db.VarChar(30)
  displayName        String    @db.VarChar(255)
  publicBio          String?   @db.Text
  mediaUrl           String?   @db.VarChar(512)
  mediaMimeType      String?   @db.VarChar(100)
  cropX              Float?
  cropY              Float?
  cropW              Float?
  cropH              Float?
  cropZoom           Float?
  cropRotation       Float?
  isPublic           Boolean   @default(true)
  displayOrder       Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SESSION STORE ────────────────────────────────────────────────────────────
model Session {
  id               String   @id @default(cuid()) @db.VarChar(30)
  userId           String   @db.VarChar(30)
  sessionTokenHash String   @unique @db.VarChar(64)
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── ACCESS KEYS ─────────────────────────────────────────────────────────────
// Stored as SHA-256 hashes — raw key is NEVER stored; shown only once on creation.
model AccessKey {
  id          String    @id @default(cuid()) @db.VarChar(30)
  userId      String    @db.VarChar(30)
  label       String    @db.VarChar(255)
  keyHash     String    @unique @db.VarChar(64)
  // role this key grants access for: "OWNER" | "ADMIN" | "TEAM_MEMBER"
  role        String    @db.VarChar(20)
  isActive    Boolean   @default(true)
  maxUses     Int?
  useCount    Int       @default(0)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs   AccessKeyAuditLog[]
}

// ─── ACCESS KEY AUDIT LOG ────────────────────────────────────────────────────
model AccessKeyAuditLog {
  id          String    @id @default(cuid()) @db.VarChar(30)
  accessKeyId String?   @db.VarChar(30)
  userId      String?   @db.VarChar(30)
  // action: "VERIFY_SUCCESS" | "VERIFY_FAIL" | "KEY_CREATED" | "KEY_REVOKED" | "KEY_REGENERATED" | "KEY_UPDATED"
  action      String    @db.VarChar(30)
  success     Boolean
  ipAddress   String?   @db.VarChar(45)
  userAgent   String?   @db.VarChar(512)
  createdAt   DateTime  @default(now())

  accessKey   AccessKey? @relation(fields: [accessKeyId], references: [id], onDelete: SetNull)
}

// ─── PRE-AUTH SESSIONS (short-lived, Access Key step only) ───────────────────
// Created after Access Key is verified; replaced by full Session after credential login.
model PreAuthSession {
  id               String   @id @default(cuid()) @db.VarChar(30)
  tokenHash        String   @unique @db.VarChar(64)
  userId           String   @db.VarChar(30)
  role             String   @db.VarChar(20)
  expiresAt        DateTime
  createdAt        DateTime @default(now())
}

// ─── PROFILE AUDIT LOG ───────────────────────────────────────────────────────
model ProfileAuditLog {
  id           String   @id @default(cuid()) @db.VarChar(30)
  actorUserId  String?  @db.VarChar(30)
  targetUserId String?  @db.VarChar(30)
  action       String   @db.VarChar(50)
  details      String   @db.Text
  createdAt    DateTime @default(now())
}