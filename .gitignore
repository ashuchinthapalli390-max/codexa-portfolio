# Dependencies
/node_modules

# Next.js
/.next/
/out/

# Production build
/build

# Environment variables — NEVER COMMIT
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# SQLite database files — never in production
prisma/*.db
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm
prisma/prisma/*.db
prisma/sqlite_dump.json
*.sqlite
*.sqlite3

# Uploaded files — ephemeral on Vercel, should use cloud storage
public/uploads/
uploads/

# TLS certificates — never commit private certs
certs/*.pem
certs/*.crt
certs/*.key
!certs/.gitkeep

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts
